# YouthIn Cameroun - Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://youthin.cm
NEXT_PUBLIC_SITE_NAME=YouthIn Cameroun

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=

# Email Configuration (Optional)
# SMTP_FROM=noreply@youthin.cm
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Mobile Money Integration (Production)
# MTN_API_KEY=
# ORANGE_API_KEY=

# Database (Optional - for future backend)
# DATABASE_URL=

# Session Secret (Production)
# SESSION_SECRET=

# Feature Flags
NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_CONTACT=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true
